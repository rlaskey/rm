{
  "tasks": {
    "main": "deno -NERWS --allow-run=magick --env-file --watch=browser --watch main.ts",
    "migrate": "deno -ERW migrations/migrate.ts"
  },
  "imports": {
    "@preact/signals": "npm:@preact/signals@^2.9.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/http": "jsr:@std/http@^1.1.2",
    "@std/testing": "jsr:@std/testing@^1.0.19",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "preact": "npm:preact@^10.29.3",
    "preact-iso": "npm:preact-iso@^2.12.0",
    "preact-render-to-string": "npm:preact-render-to-string@^6.7.0",
    "zod": "npm:zod@^4.4.3"
  },
  "compilerOptions": {
    "lib": ["dom", "node", "deno.ns", "deno.unstable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "unstable": ["bundle"],
  "test": { "sanitizeOps": true, "sanitizeResources": true }
}
