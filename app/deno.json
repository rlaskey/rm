    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/http": "jsr:@std/http@^1.1.1",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "preact": "npm:preact@^10.29.2",
    "preact-iso": "npm:preact-iso@^2.12.0",
    "preact-render-to-string": "npm:preact-render-to-string@^6.7.0"
